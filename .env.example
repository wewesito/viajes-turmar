ALLOWED_ORIGIN=https://viajesturmar.com
PUBLIC_SITE_URL=https://viajesturmar.com
PUBLIC_BRAND_NAME=Viajes Turmar
PUBLIC_CONTACT_EMAIL=info@viajesturmar.com
PUBLIC_SALES_EMAIL=reservas@viajesturmar.com

# Supabase server-side only. Never expose this key in browser code.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Optional CRM/team notifications.
LEAD_WEBHOOK_URL=

# Private wholesale/metasearch engine backend.
TURMAR_ENGINE_URL=
TURMAR_ENGINE_TOKEN=

# Optional provider credentials, stored only in hosting env vars.
MAYORISTA_1_USER=
MAYORISTA_1_PASSWORD=
MAYORISTA_2_TOKEN=

# Payments/auth placeholders.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
REDSYS_MERCHANT_CODE=
ADMIN_SESSION_SECRET=replace-with-long-random-secret
